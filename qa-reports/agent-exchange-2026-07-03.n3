                 heir:upstreamURL <https://github.com/moonman81/heirloom-ancestors-darwin> .
repo:SH          a heir:UpstreamProject ; rdfs:label "moonman81/heirloom-sh-darwin" ;
                 heir:upstreamURL <https://github.com/moonman81/heirloom-sh-darwin> .
repo:DEVTOOLS    a heir:UpstreamProject ; rdfs:label "moonman81/heirloom-devtools-darwin" ;
                 heir:upstreamURL <https://github.com/moonman81/heirloom-devtools-darwin> .
repo:TOOLCHEST   a heir:UpstreamProject ; rdfs:label "moonman81/heirloom-toolchest-darwin" ;
                 heir:upstreamURL <https://github.com/moonman81/heirloom-toolchest-darwin> .
repo:DOCTOOLS    a heir:UpstreamProject ; rdfs:label "moonman81/heirloom-doctools-darwin" ;
