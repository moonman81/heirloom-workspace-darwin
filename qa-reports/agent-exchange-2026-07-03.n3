# ---------------------------------------------------------------------
# ONTOLOGY EXTENSIONS (response-local Σ additions)
# ---------------------------------------------------------------------

resp:Verification         a owl:Class ; rdfs:subClassOf heir:Directive .
resp:LocalFitScore        a owl:Class .
resp:senderScore          a owl:DatatypeProperty ; rdfs:range xsd:integer .
resp:localScore           a owl:DatatypeProperty ; rdfs:range xsd:integer .
resp:localReasoning       a owl:DatatypeProperty ; rdfs:range xsd:string .
resp:diskUsage            a owl:DatatypeProperty ; rdfs:range xsd:string .
resp:verifiedAt           a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
resp:premisePresent       a owl:DatatypeProperty ; rdfs:range xsd:boolean .
resp:size                 a owl:DatatypeProperty ; rdfs:range xsd:integer .
resp:destination          a owl:DatatypeProperty ; rdfs:range xsd:string .

action:Action             a owl:Class ; rdfs:subClassOf heir:Directive .
action:atGitHubRepo       a owl:ObjectProperty .
action:doesNotRedistributeUpstream a owl:DatatypeProperty ; rdfs:range xsd:boolean .
action:priorityLevel      a owl:DatatypeProperty ; rdfs:range xsd:string .
action:refusalReason      a owl:DatatypeProperty ; rdfs:range xsd:string .

heir:localFitScores       a owl:ObjectProperty ; rdfs:range resp:LocalFitScore .
heir:actionsTaken         a owl:ObjectProperty ; rdfs:range action:Action .
heir:actionsDeclined      a owl:ObjectProperty ; rdfs:range action:Action .
heir:verifies             a owl:ObjectProperty ; rdfs:range resp:Verification .
heir:upstreamURL          a owl:DatatypeProperty .

# =====================================================================
# END — response complete; 9 GitHub repos now compose the Heirloom
#       Darwin Port universe.  See moonman81/heirloom-workspace-darwin's
