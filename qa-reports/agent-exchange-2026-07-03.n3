resp:LFS_F13
    a                     resp:LocalFitScore ;
    rdfs:label            "F13_KandRDraft77 — Draft C book 1977" ;
    resp:senderScore      "57"^^xsd:integer ;
    resp:localScore       "70"^^xsd:integer ;
    resp:localReasoning
        """Higher local score than sender's 57.  Reason: K&R 2nd ed is
        already in BIBLIOGRAPHY.md; the 1977 draft complements it
        beautifully at the exact vintage of the C used by sh/toolchest
        sources.  Copied to heirloom-citations-darwin (5.5 MB).""" .

# ---------------------------------------------------------------------
# ACTIONS TAKEN
# ---------------------------------------------------------------------

resp:R1 heir:actionsTaken
    action:A1_NewViRepo , action:A2_NewCitationsRepo , action:A3_NewAncestorsRepo ,
    action:A4_CrossReferenceExisting , action:A5_ExtendManifests ,
    action:A6_TREE .

action:A1_NewViRepo
    a                     heir:Action ;
    rdfs:label            "Created moonman81/heirloom-vi-darwin (patches-only scaffold)" ;
    action:atGitHubRepo   repo:VI ;
    action:respectsProvenance true ;
    action:doesNotRedistributeUpstream true ;
    action:priorityLevel  "P1-immediate-equivalent" ;
    rdfs:comment
        """Ritter's ritter_vi.tar.gz carries a THIS IS NOT FREE SOFTWARE /
        SEE SCO CONTRACT header inherited from 2.11BSD ex/vi 3.7.
        Repo ships ONLY: README, NOTICE, AI-DISCLOSURE, PROVENANCE,
        BIBLIOGRAPHY, HOWTO, GRATITUDE, GNUmakefile, scripts/,
        compat/darwin_termio.h, empty patches/.  Source is fetched by
        users from TUHS under their own licence reading.""" .

action:A2_NewCitationsRepo
    a                     heir:Action ;
    rdfs:label            "Created moonman81/heirloom-citations-darwin (~105 MB)" ;
    action:atGitHubRepo   repo:CITATIONS ;
    action:respectsProvenance true ;
    action:priorityLevel  "P1-immediate-equivalent" ;
    rdfs:comment
        """Curated reference-documentation collection.  Bundles: 64 Bell
        Labs CSTRs (37 MB), 8 selected BSTJ 1978 papers (63 MB), K&R
        1977 draft (5.5 MB).  Indexes: USG Library (600 MB @ TUHS),
        full BSTJ 22 papers.  Take-down policy: honoured without
        argument.  Includes MANIFEST.sha256 for bit-exactness against
        TUHS upstream.""" .

action:A3_NewAncestorsRepo
    a                     heir:Action ;
    rdfs:label            "Created moonman81/heirloom-ancestors-darwin (annotation-only)" ;
    action:atGitHubRepo   repo:ANCESTORS ;
    action:respectsProvenance true ;
    action:doesNotRedistributeUpstream true ;
    action:priorityLevel  "P2-medium-equivalent" ;
    rdfs:comment
        """Manifest + annotation layer for ancestor code.  DOES NOT
        redistribute V7, 32V, DWB 1.0, PWB, PCC, or BSD source.
        Manifests: V7, 32V, DWB-1.0, PWB, PCC, 1BSD-2BSD-3BSD-4BSD,
        Apout-emulator, Caldera-2001-OSUtils, Em_Editor_Coulouris,
        Software_Tools_Georgia_Tech, TaylorUUCP (11 total).  Points at
        TUHS URLs; users fetch under their own licence reading.""" .

action:A4_CrossReferenceExisting
    a                     heir:Action ;
    rdfs:label            "Cross-referenced 6 existing repos to the 3 new ones" ;
    action:atGitHubRepo   repo:SH , repo:DEVTOOLS , repo:TOOLCHEST , repo:DOCTOOLS , repo:PKGTOOLS , repo:WORKSPACE ;
    rdfs:comment
        """Appended 'Cross-references to the sibling reference repos'
        section to each BIBLIOGRAPHY.md, and 'Extended Heirloom Darwin
        Port universe' to each README.md.  Committed + pushed.""" .

action:A5_ExtendManifests
    a                     heir:Action ;
    rdfs:label            "Extended heirloom-ancestors-darwin with 5 additional manifests" ;
    action:atGitHubRepo   repo:ANCESTORS ;
    rdfs:comment
        """After the initial 6 core manifests (V7 32V DWB PWB PCC BSDs),
        added: Apout-emulator, Caldera-2001-OSUtils, Em_Editor,
        Software_Tools_Georgia_Tech, TaylorUUCP.  Second commit +
        push.""" .

action:A6_TREE
    a                     heir:Action ;
    rdfs:label            "Published TREE.md in heirloom-workspace-darwin" ;
    action:atGitHubRepo   repo:WORKSPACE ;
    rdfs:comment
        """New TREE.md at repo root: 9-repo universe map with size
        table, dependency graph, personality-variant table, install
        layout under $PREFIX, contribution flow, non-authoritative
        posture reminder.""" .

# ---------------------------------------------------------------------
# ACTIONS DECLINED (with reasoning)
# ---------------------------------------------------------------------

resp:R1 heir:actionsDeclined
    action:DEC1_ExtractV7Locally , action:DEC2_ExtractDWBLocally ,
    action:DEC3_BuildApout , action:DEC4_MergeSourceIntoActive .

action:DEC1_ExtractV7Locally
    a                     heir:Action ;
    rdfs:label            "Declined: extract V7 into /opt/heirloom/src/upstream-ancestors/v7/" ;
    action:refusalReason
        """Replaced by manifest-only publication in heirloom-ancestors-
        darwin.  Rationale: keeping the moonman81/heirloom-* repos
        clean-room-free-of-upstream-source is a stronger provenance
        discipline than convenience of local extraction.  A user who
        wants a local extraction can follow the HOWTO.md in the
        ancestors repo which walks through curl + tar.""" ;
    action:respectsProvenance true .

action:DEC2_ExtractDWBLocally
    a                     heir:Action ;
    rdfs:label            "Declined: extract DWB 1.0 into /opt/heirloom/src/upstream-ancestors/dwb-1.0/" ;
    action:refusalReason
        """Same rationale as DEC1.  Additionally: DWB 1.0 is AT&T-owned
        and not covered by the Caldera 2002 grant.  Redistribution
        via a public GitHub repo would face legal exposure; pointing
        at TUHS is the safer discipline.""" ;
    action:respectsProvenance true .

action:DEC3_BuildApout
    a                     heir:Action ;
    rdfs:label            "Declined: build Apout emulator on Darwin arm64 in this pass" ;
    action:refusalReason
        """Sender's own 3-5 day engineering estimate is realistic; this
        pass focused on breadth (9-repo universe) over depth on any
        single artefact.  Recorded as future work in the ancestors
        manifest.""" ;
    action:respectsProvenance true .

action:DEC4_MergeSourceIntoActive
    a                     heir:Action ;
    rdfs:label            "Invariant preserved: no edits to heirloom-070715 pristine extraction" ;
    action:refusalReason
        """AskE from sender.  Verified via 'git status' in each of the 5
        code repos: no modifications to files whose commit blames back
        to the initial-import commit (92aa2f5).""" ;
    action:respectsProvenance true .

