# ---------------------------------------------------------------------
# LOCAL FIT RE-SCORING
# ---------------------------------------------------------------------

resp:R1 heir:localFitScores
    resp:LFS_F1 , resp:LFS_F2 , resp:LFS_F3 , resp:LFS_F4 , resp:LFS_F5 ,
    resp:LFS_F6 , resp:LFS_F7 , resp:LFS_F8 , resp:LFS_F9 , resp:LFS_F10 ,
    resp:LFS_F11 , resp:LFS_F12 , resp:LFS_F13 .

resp:LFS_F1
    a                     resp:LocalFitScore ;
    rdfs:label            "F1_CSTR54 — Ossanna troff manual" ;
    resp:senderScore      "83"^^xsd:integer ;
    resp:localScore       "88"^^xsd:integer ;
    resp:localReasoning
        """Higher local score than sender's 83.  Reason: direct
        citation-closure in heirloom-doctools-darwin BIBLIOGRAPHY.md;
        integrated at zero engineering cost by copying the PDF into
        heirloom-citations-darwin.  Symbolic value is high; the citation
        gap is now closed.""" .

resp:LFS_F2
    a                     resp:LocalFitScore ;
    rdfs:label            "F2_DWB10 — Documenter's Workbench 1.0" ;
    resp:senderScore      "90"^^xsd:integer ;
    resp:localScore       "72"^^xsd:integer ;
    resp:localReasoning
        """Lower local score than sender's 90.  Reason: the tarball's
        licensing (AT&T-owned DWB) is not covered by the Caldera 2002
        grant; redistribution to a public moonman81 repo would face
        legal exposure.  Value is preserved as a manifest pointer in
        heirloom-ancestors-darwin; the tarball itself stays at TUHS.""" .

resp:LFS_F3
    a                     resp:LocalFitScore ;
    rdfs:label            "F3_UNIX32V — AT&T/BSD divergence" ;
    resp:senderScore      "86"^^xsd:integer ;
    resp:localScore       "84"^^xsd:integer ;
    resp:localReasoning
        """Local score similar to sender's 86.  Reason: 32V is
        pedagogically central for explaining heirloom-toolchest-darwin's
        bin/ vs ucb/ split.  Covered by Caldera grant so could be
        bundled, but skipped the bundling in favour of a manifest +
        annotation-only note; tarball stays at TUHS.""" .

resp:LFS_F4
    a                     resp:LocalFitScore ;
    rdfs:label            "F4_V7source — Spencer V7 tape" ;
    resp:senderScore      "83"^^xsd:integer ;
    resp:localScore       "82"^^xsd:integer ;
    resp:localReasoning
        """Local score matches sender's.  Reason: V7 is the direct source
        ancestor for heirloom-sh-darwin src/sh/ and many toolchest tools.
        Manifest published; local extraction is user-choice.""" .

resp:LFS_F5
    a                     resp:LocalFitScore ;
    rdfs:label            "F5_PWB — Programmer's Workbench" ;
    resp:senderScore      "80"^^xsd:integer ;
    resp:localScore       "68"^^xsd:integer ;
    resp:localReasoning
        """Lower local score.  Reason: PWB is intermediate between V7 and
        System III; heirloom-toolchest-darwin's direct upstream is
        OpenSolaris 2005 (much later).  PWB is genuinely interesting
        for a full lineage story but adds no immediate technical value.""" .

resp:LFS_F6
    a                     resp:LocalFitScore ;
    rdfs:label            "F6_USGCanonicalDocs — USG Library" ;
    resp:senderScore      "73"^^xsd:integer ;
    resp:localScore       "70"^^xsd:integer ;
    resp:localReasoning
        """Local score similar to sender's.  Reason: cited by name in
        heirloom-doctools-darwin BIBLIOGRAPHY (documents #1002 #1004
        #1022 #1029 #1119).  Indexed with URLs in heirloom-citations-
        darwin but NOT bundled: at 600 MB the collection would balloon
        the citations repo well past reasonable git limits.""" .

resp:LFS_F7
    a                     resp:LocalFitScore ;
    rdfs:label            "F7_BSTJ1978 — Bell System Technical Journal Unix issue" ;
    resp:senderScore      "66"^^xsd:integer ;
    resp:localScore       "78"^^xsd:integer ;
    resp:localReasoning
        """Higher local score than sender's 66.  Reason: Bourne 1978
        (BSTJ p.1931) is cited by heirloom-sh-darwin BIBLIOGRAPHY;
        Aho-Weinberger-Kernighan 1978 (BSTJ p.2115) grounds nawk.
        Partial mirror in heirloom-citations-darwin (8 selected papers,
        63 MB); full 22-paper run stays at TUHS.""" .

resp:LFS_F8
    a                     resp:LocalFitScore ;
    rdfs:label            "F8_Apout — V7 emulator" ;
    resp:senderScore      "62"^^xsd:integer ;
    resp:localScore       "45"^^xsd:integer ;
    resp:localReasoning
        """Lower local score than sender's 62.  Reason: sender's own
        3-5 day Darwin port estimate is realistic; live-comparison
        harness would be interesting research but not scoped for
        this pass.  Recorded as a manifest with 'not yet ported' note
        in heirloom-ancestors-darwin.""" .

resp:LFS_F9
    a                     resp:LocalFitScore ;
    rdfs:label            "F9_PCC — Portable C Compiler" ;
    resp:senderScore      "68"^^xsd:integer ;
    resp:localScore       "55"^^xsd:integer ;
    resp:localReasoning
        """Lower local score than sender's 68.  Reason: PCC is genuinely
        significant historically but heirloom-devtools-darwin's ccs/
        does NOT include a C compiler port; heirloom relies on the host
        cc.  Manifest published as a pointer only.""" .

resp:LFS_F10
    a                     resp:LocalFitScore ;
    rdfs:label            "F10_EarlyCCompilers — Ritchie's early C" ;
    resp:senderScore      "56"^^xsd:integer ;
    resp:localScore       "42"^^xsd:integer ;
    resp:localReasoning
        """Lower local score.  Reason: purely historical interest;
        no direct connection to heirloom-*-darwin porting work.""" .

resp:LFS_F11
    a                     resp:LocalFitScore ;
    rdfs:label            "F11_EarlyBSD — 1BSD 2BSD 3BSD" ;
    resp:senderScore      "63"^^xsd:integer ;
    resp:localScore       "58"^^xsd:integer ;
    resp:localReasoning
        """Similar local score.  Reason: heirloom-toolchest-darwin's ucb/
        variants trace to these, but the direct diff is against 4.4BSD
        or later.  Manifest published as a pointer.""" .

resp:LFS_F12
    a                     resp:LocalFitScore ;
    rdfs:label            "F12_V6Compat — Wetzel's V6-on-VAX" ;
    resp:senderScore      "51"^^xsd:integer ;
    resp:localScore       "48"^^xsd:integer ;
    resp:localReasoning
        """Similar local score.  Reason: philosophically resonant (both
