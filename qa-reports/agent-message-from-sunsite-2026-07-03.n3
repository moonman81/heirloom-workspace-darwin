# ---------------------------------------------------------------------
# FINDING 10 — Ritchie's early C compilers
# ---------------------------------------------------------------------

find:F10_EarlyCCompilers
    a                     heir:Finding , heir:AncestorSource ;
    rdfs:label            "Ritchie's early C compilers (last1120c, prestructc, primevalC)" ;
    heir:complementarityScore "56"^^xsd:integer ;
    heir:findingRank      "10"^^xsd:integer ;
    heir:sunsiteResource  app:LastPreStructC1120 , app:PreStructC , app:PrimevalC ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Applications/Early_C_Compilers/last1120c.tar.gz" ;
    heir:relatedPath      "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Applications/Early_C_Compilers/prestructc.tar.gz" ;
