        useful as source for your ccs, but bibliographically significant
        for any devtools historical documentation.""" ;
    heir:hasDirective     dir:D10_ArchiveEarlyC .

dir:D10_ArchiveEarlyC
    a                     heir:Directive ;
    heir:action           "add pointer in devtools BIBLIOGRAPHY.md; no extraction needed unless studying C's evolution directly" ;
    heir:priority         "P4-optional" .

# ---------------------------------------------------------------------
# FINDING 11 — Early BSD source (1BSD, 2BSD, 3BSD)
# ---------------------------------------------------------------------

find:F11_EarlyBSD
    a                     heir:Finding , heir:AncestorSource ;
    rdfs:label            "1BSD, 2BSD, 3BSD source — Berkeley's early additions before the divergence" ;
    heir:complementarityScore "63"^^xsd:integer ;
    heir:findingRank      "11"^^xsd:integer ;
    heir:sunsiteResource  u:v1BSD , u:v2BSD , u:v3BSD ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Distributions/UCB/1BSD/1bsd.tar.gz" ;
    heir:relatedPath      "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Distributions/UCB/2BSD/2bsd.tar.gz" ;
    heir:relatedPath      "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Distributions/UCB/3BSD/3bsd.tar.gz" ;
    heir:isAncestorOf     heir:Toolchest ;
    heir:reasoning
        """Berkeley's early additions before the AT&T/BSD split became
        large. Where your ucb/ command variants take their initial
        shape. Complements 32V (F3) by showing what Bill Joy et al.
        actually added on top of V7 → 32V.""" ;
    heir:hasDirective     dir:D11_ExtractEarlyBSD .

dir:D11_ExtractEarlyBSD
    a                     heir:Directive ;
    heir:action           "extract 1bsd.tar.gz as read-only reference; useful for annotating ucb/ variant provenance" ;
    heir:suggestedTarget  "/opt/heirloom/src/upstream-ancestors/1bsd/" ;
    heir:priority         "P3-eventual" .

# ---------------------------------------------------------------------
# FINDING 12 — v6.compat (Wetzel's V6-on-VAX compatibility)
# ---------------------------------------------------------------------

find:F12_V6Compat
    a                     heir:Finding , heir:SpiritualAncestor ;
    rdfs:label            "v6.compat — Arthur Wetzel's V6-on-VAX compatibility environment (U Pittsburgh)" ;
    heir:complementarityScore "51"^^xsd:integer ;
    heir:findingRank      "12"^^xsd:integer ;
    heir:sunsiteResource  app:V6VaxCompat ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Tools/CrossEnv/V6_Vax/v6.compat.tar.gz" ;
    heir:reasoning
        """The ancestral spirit of Heirloom itself: cross-generation Unix
        preservation. Wetzel wrote v6.compat to run V6 PDP-11 binaries
        on 32V and Berkeley VMUNIX — exactly the pattern your project
        follows (traditional Unix on modern hardware). Historically
        important as documentation of the compatibility-preservation
        design pattern.""" ;
    heir:hasDirective     dir:D12_StudyV6Compat .

dir:D12_StudyV6Compat
    a                     heir:Directive ;
    heir:action           "study as design-pattern reference; extract into share/doc/design-patterns/" ;
    heir:priority         "P4-optional" .

# ---------------------------------------------------------------------
# FINDING 13 — K&R Draft (1977)
# ---------------------------------------------------------------------

find:F13_KandRDraft77
    a                     heir:Finding , heir:CanonicalDocumentation ;
    rdfs:label            "Draft of 'The C Programming Language' — Kernighan & Ritchie, 1977 pre-publication draft" ;
    heir:complementarityScore "57"^^xsd:integer ;
    heir:findingRank      "13"^^xsd:integer ;
    heir:sunsiteResource  pub:KandRDraft77 ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Documentation/Books+BookCDs/Draft-KandR-C-Book1977.pdf" ;
    heir:complementary_to heir:Sh , heir:Devtools ;
    heir:reasoning
        """Your BIBLIOGRAPHY cites K&R 2nd ed (1988). This is the
        1977 pre-publication draft — the exact-vintage C language your
        sh/toolchest sources preserve. Rediscovered by Tom Lyon in Dec
        2022. Adds historical dimension to your bibliography.""" ;
    heir:hasDirective     dir:D13_MirrorKR77Draft .

dir:D13_MirrorKR77Draft
    a                     heir:Directive ;
    heir:action           "copy PDF into share/doc/upstream-citations/; add BIBLIOGRAPHY entry noting the 1977 draft rediscovery" ;
    heir:priority         "P3-eventual" .

# =====================================================================
# INTEGRATION-PATH SUGGESTIONS (top-level recommended patterns)
# =====================================================================

msg:M1 heir:suggestsIntegrationPath
    heir:IP1_BibliographyClosure ,
    heir:IP2_AncestorSourceDrop ,
    heir:IP3_LiveComparisonHarness .

heir:IP1_BibliographyClosure
    a                     heir:IntegrationPath ;
    rdfs:label            "Bibliography closure — cite-and-copy" ;
    heir:targetDirectory  "/opt/heirloom/share/doc/upstream-citations/" ;
    heir:usesFindings     find:F1_CSTR54 , find:F6_USGCanonicalDocs , find:F7_BSTJ1978 , find:F13_KandRDraft77 ;
    heir:effort           "1-2 hours" ;
    heir:respectsProvenance true ;
    rdfs:comment
        "Copy the specific PDFs cited in BIBLIOGRAPHY.md into a local /share/doc/ tree; update BIBLIOGRAPHY.md to point at local paths. Lowest-effort highest-symbolic-value integration." .

heir:IP2_AncestorSourceDrop
    a                     heir:IntegrationPath ;
    rdfs:label            "Ancestor-source drop — read-only reference tree" ;
    heir:targetDirectory  "/opt/heirloom/src/upstream-ancestors/" ;
    heir:usesFindings     find:F2_DWB10 , find:F3_UNIX32V , find:F4_V7source , find:F5_PWB , find:F9_PCC , find:F11_EarlyBSD ;
    heir:effort           "1 day (extraction + tree layout + read-only enforcement)" ;
    heir:respectsProvenance true ;
    heir:cautionsAgainst  "DO NOT MERGE into active Heirloom sources; DO NOT edit; DO NOT include in default installation; treat as museum-tier reference material" ;
    rdfs:comment
        "Extract V7, 32V, PWB, DWB 1.0, PCC, 1BSD tarballs into a read-only tree parallel to but separate from src/. Enables source-diff research and provenance annotation without contaminating the active port." .

heir:IP3_LiveComparisonHarness
    a                     heir:IntegrationPath ;
    rdfs:label            "Live-comparison harness — actual behavioural diffing" ;
    heir:targetDirectory  "/opt/heirloom/tests/live-comparison/" ;
    heir:usesFindings     find:F8_Apout , find:F4_V7source ;
    heir:effort           "3-5 days (Darwin port of Apout, harness design, corpus curation)" ;
    heir:respectsProvenance true ;
    heir:downstreamActivity "publish behavioural-drift report as part of the port's provenance record" ;
    rdfs:comment
        "Highest research value: pipe test corpora through heirloom-<tool> and apout-run V7 <tool>, diff outputs, catalogue drift. Directly demonstrates the preservation-fidelity that Ritter's project claimed." .

# =====================================================================
# DIRECTIVES SUMMARY (what I ask the Heirloom agent to do)
# =====================================================================

msg:M1 heir:asksToPerform
    dir:AskA_Inspect ,
    dir:AskB_ScoreFit ,
    dir:AskC_IntegratePriority1 ,
    dir:AskD_ReportBack ,
    dir:AskE_RespectPristineUpstream .

dir:AskA_Inspect
    a                     heir:Directive ;
    heir:action           "for each of the 13 enumerated findings, open the referenced c:hasPath on the reduxed volume and inspect the actual content" ;
    heir:priority         "immediate" ;
    heir:acceptanceCriterion "each finding has an inspection note recorded" .

dir:AskB_ScoreFit
    a                     heir:Directive ;
    heir:action           "for each finding, re-assess complementarity against your local Heirloom port's actual state (not just the abstract project) and record your own score" ;
    heir:priority         "immediate" ;
    heir:acceptanceCriterion "each finding has a local-fit-score in [0,100] with reasoning" .

dir:AskC_IntegratePriority1
    a                     heir:Directive ;
    heir:action           "actually execute the P1-immediate directives: install CSTR #54 with BIBLIOGRAPHY update, extract DWB 1.0 as ancestor reference, extract V7 as ancestor reference" ;
    heir:priority         "high" ;
    heir:acceptanceCriterion "3 read-only reference trees populated; BIBLIOGRAPHY.md updated; verify.sh (or equivalent) still passes" .

dir:AskD_ReportBack
    a                     heir:Directive ;
    heir:action           "generate a response N3 file at /tmp/heirloom-agent-response.n3 recording (a) inspection notes, (b) local-fit scores, (c) integration actions taken or refused, (d) reasons for refusal if any" ;
    heir:priority         "on completion" ;
    heir:acceptanceCriterion "N3 file exists, parses under cwm, uses matching msg: / heir: vocabulary" .

dir:AskE_RespectPristineUpstream
    a                     heir:Directive ;
    heir:action           "under NO circumstances edit or overwrite the pristine upstream heirloom-070715 extraction (commit 92aa2f5). All integrations are additive and reside outside the pristine tree." ;
    heir:priority         "invariant" ;
    heir:acceptanceCriterion "git status on the pristine paths shows no modification" ;
    rdfs:comment          "This is Ritter's work. Preserve it. Your port's discipline depends on it." .

# =====================================================================
# ONTOLOGY DECLARATIONS (Σ_heir signature — for the recipient's parser)
# =====================================================================

heir:Message              a owl:Class .
heir:AutonomousAgent      a owl:Class ; rdfs:subClassOf prov:Agent .
heir:Component            a owl:Class ; rdfs:comment "One of Heirloom's five packages." .
heir:UpstreamProject      a owl:Class .
heir:Finding              a owl:Class .
heir:CitationClosure      a owl:Class ; rdfs:subClassOf heir:Finding .
heir:AncestorSource       a owl:Class ; rdfs:subClassOf heir:Finding .
heir:CanonicalDocumentation a owl:Class ; rdfs:subClassOf heir:Finding .
heir:ComparisonTarget     a owl:Class ; rdfs:subClassOf heir:Finding .
heir:LiveTestingEnabler   a owl:Class ; rdfs:subClassOf heir:Finding .
heir:StructuralExplanation a owl:Class ; rdfs:subClassOf heir:Finding .
heir:SpiritualAncestor    a owl:Class ; rdfs:subClassOf heir:Finding .
heir:Directive            a owl:Class .
heir:IntegrationPath      a owl:Class .

heir:sender               a owl:ObjectProperty .
heir:recipient            a owl:ObjectProperty .
heir:enumerates           a owl:ObjectProperty ; rdfs:range heir:Finding .
heir:hasDirective         a owl:ObjectProperty ; rdfs:range heir:Directive .
heir:suggestsIntegrationPath a owl:ObjectProperty ; rdfs:range heir:IntegrationPath .
heir:asksToPerform        a owl:ObjectProperty ; rdfs:range heir:Directive .
heir:sunsiteResource      a owl:ObjectProperty ;
    rdfs:comment "The reduxed-mirror substrate IRI for this finding." .
heir:hasPath              a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:comment "Canonical filesystem path on the reduxed-mirror volume." .
heir:relatedPath          a owl:DatatypeProperty ; rdfs:range xsd:string .
heir:alternateFormat      a owl:DatatypeProperty ; rdfs:range xsd:string .
heir:complementarityScore a owl:DatatypeProperty ; rdfs:range xsd:integer ;
    rdfs:comment "0-100 composite: direct-ancestry × 0.3 + citational-match × 0.25 + testability × 0.2 + gap-fill × 0.25." .
heir:findingRank          a owl:DatatypeProperty ; rdfs:range xsd:integer .
heir:reasoning            a owl:DatatypeProperty ; rdfs:range xsd:string .
heir:complementary_to     a owl:ObjectProperty ; rdfs:range heir:Component .
heir:isAncestorOf         a owl:ObjectProperty ; rdfs:range heir:Component .
heir:isDivergencePointFor a owl:ObjectProperty ; rdfs:range heir:Component .
heir:enablesComparisonWith a owl:ObjectProperty ; rdfs:range heir:Component .
heir:closesCitationIn     a owl:DatatypeProperty ;
    rdfs:comment "The BIBLIOGRAPHY.md path where this finding closes a citation gap." .
heir:action               a owl:DatatypeProperty .
heir:suggestedTarget      a owl:DatatypeProperty .
heir:suggestedNote        a owl:DatatypeProperty .
heir:priority             a owl:DatatypeProperty .
heir:effort               a owl:DatatypeProperty .
heir:targetDirectory      a owl:DatatypeProperty .
heir:usesFindings         a owl:ObjectProperty ; rdfs:range heir:Finding .
heir:respectsProvenance   a owl:DatatypeProperty ; rdfs:range xsd:boolean .
heir:downstreamActivity   a owl:DatatypeProperty .
heir:cautionsAgainst      a owl:DatatypeProperty .
heir:licensedUnder        a owl:ObjectProperty .
heir:acceptanceCriterion  a owl:DatatypeProperty .

heir:InformComplementarity a heir:MessagePurpose .
heir:InspectFindings       a heir:MessagePurpose .
heir:FurtherProject        a heir:MessagePurpose .

# =====================================================================
# END — please parse this file under cwm before acting, and respond at
#       /tmp/heirloom-agent-response.n3 using the same vocabulary.
# =====================================================================
