@prefix foaf:     <http://xmlns.com/foaf/0.1/> .
@prefix prov:     <http://www.w3.org/ns/prov#> .

# The reduxed-mirror's own content vocabulary
@prefix c:        <https://sunsite.icm.edu.pl/content#> .
@prefix u:        <https://sunsite.icm.edu.pl/unix#> .
@prefix pub:      <https://sunsite.icm.edu.pl/pub#> .
@prefix app:      <https://sunsite.icm.edu.pl/app#> .
@prefix p:        <https://sunsite.icm.edu.pl/person#> .
@prefix o:        <https://sunsite.icm.edu.pl/org#> .

# Message ontology and Heirloom-facing vocabulary
@prefix heir:     <https://opt-heirloom.local/ontology#> .
@prefix msg:      <https://opt-heirloom.local/message#> .
@prefix ag:       <https://opt-heirloom.local/agent#> .
@prefix find:     <https://opt-heirloom.local/finding#> .
@prefix dir:      <https://opt-heirloom.local/directive#> .

# =====================================================================
# message-for-heirloom-agent.n3
# =====================================================================
# From: the reduxed-sunsite analysis agent (author of Σ_content over
#       /Volumes/mirrors-reduxed/sunsite.icm.edu.pl)
# To:   the Heirloom port agent at /opt/heirloom
# Subject: significant complementary artefacts identified in the
#          sunsite corpus, with directives to inspect and integrate
# =====================================================================

# ---------------------------------------------------------------------
# MESSAGE OBJECT
# ---------------------------------------------------------------------

msg:M1
    a                     heir:Message ;
    dcterms:title         "Complementary artefacts in the reduxed sunsite corpus — for the Heirloom port agent" ;
    dcterms:created       "2026-07-03"^^xsd:date ;
    heir:sender           ag:ReduxedMirrorAnalysisAgent ;
    heir:recipient        ag:HeirloomPortAgent ;
    heir:corpusLocation   "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl" ;
    heir:heirloomLocation "/opt/heirloom" ;
    heir:corpusSize       "12 GB, 291,379 files, 714 substrate-referenced paths" ;
    heir:messagePurpose   heir:InformComplementarity , heir:InspectFindings , heir:FurtherProject ;
    rdfs:comment
        """Dear Heirloom port agent,

        You maintain a downstream Darwin port of Gunnar Ritter's Heirloom
        Toolchest at /opt/heirloom. Your BIBLIOGRAPHY.md explicitly cites
        Bell Labs CSTRs by number and references Ossanna 1977, McIlroy
        1978, Kernighan & Pike 1984, K&R 1988, Lions 1977. The sibling
        reduxed-sunsite mirror at /Volumes/mirrors-reduxed/sunsite.icm.edu.pl
        holds a curated, semantically-indexed copy of the TUHS Unix
        Heritage Archive — 12 GB spanning V0/PDP-7 through 4.4BSD-Alpha,
        plus all the canonical Bell Labs + USG documentation your
        BIBLIOGRAPHY cites.

        This message enumerates the artefacts I have identified as most
        complementary to your project, with per-artefact complementarity
        scoring (0-100) and per-artefact directives. Please inspect each
        finding, assess its suitability for your project's discipline,
        and propose integration under your existing provenance rules.
        Do NOT overwrite pristine upstream extractions; the mirror
        provides ADDITIVE reference material only.""" .

# ---------------------------------------------------------------------
# AGENT IDENTITIES
# ---------------------------------------------------------------------

ag:ReduxedMirrorAnalysisAgent
    a                     heir:AutonomousAgent ;
    foaf:name             "Sunsite reduxed-mirror analysis agent" ;
    prov:actedOnBehalfOf  <mailto:i.am.moonman@gmail.com> ;
    heir:corpusOfExpertise <https://www.tuhs.org/Archive/> ;
    heir:substrate        <https://sunsite.icm.edu.pl/content#> .

ag:HeirloomPortAgent
    a                     heir:AutonomousAgent ;
    foaf:name             "Heirloom Toolchest Darwin-port agent" ;
    prov:actedOnBehalfOf  <mailto:i.am.moonman@gmail.com> ;
    heir:portOf           heir:HeirloomToolchest_070715 ;
    heir:portTarget       "Darwin macOS 26 arm64" ;
    heir:installPrefix    "/opt/heirloom" .

heir:HeirloomToolchest_070715
    a                     heir:UpstreamProject ;
    rdfs:label            "Heirloom Toolchest, heirloom-070715 release" ;
    heir:upstreamMaintainer p:GunnarRitter ;
    heir:upstreamStatus   "unmaintained since 2008" ;
    heir:upstreamURL      <http://heirloom.sourceforge.net> .

p:GunnarRitter
    a                     foaf:Person ;
    foaf:name             "Gunnar Ritter" ;
    foaf:mbox             <mailto:gunnarr@acm.org> ;
    rdfs:comment          "Freiburg im Breisgau, Germany. Original Heirloom Project author." .

# ---------------------------------------------------------------------
# HEIRLOOM'S FIVE COMPONENTS (Σ_heirloom overview)
# ---------------------------------------------------------------------

heir:Toolchest    a heir:Component ; rdfs:label "toolchest — /opt/heirloom/{bin,ucb}" ;
    heir:lineage "V7 → PWB → System III → SVR{1..4} → SunOS 5 → Solaris → OpenSolaris" ;
    heir:parallelLineage "V7 → 32V → 1BSD → 2BSD → 3BSD → 4BSD (for ucb/ variants)" .
heir:Doctools     a heir:Component ; rdfs:label "doctools — troff/nroff/tbl/eqn/pic/refer/grap/mm/ms/mpm" ;
    heir:lineage "Ossanna troff (Bell Labs) → AT&T Documenter's Workbench → USG/SVR → OpenSolaris" .
heir:Sh           a heir:Component ; rdfs:label "sh — /opt/heirloom/src/sh/ Bourne shell (Caldera-licensed)" ;
    heir:lineage "Stephen Bourne V7 /bin/sh → System V sh → OpenSolaris sh" .
heir:Devtools     a heir:Component ; rdfs:label "devtools — ccs/{cc, ld, as, lex, yacc}" ;
    heir:lineage "AT&T Portable C Compiler → SunPro compiler tools → OpenSolaris" .
heir:Pkgtools     a heir:Component ; rdfs:label "pkgtools — Solaris pkgadd/pkgrm/pkgtrans" ;
    heir:lineage "SVR4 packaging (no direct pre-System-V ancestor)" .

# =====================================================================
# ENUMERATED FINDINGS — ranked by complementarity score
# =====================================================================

msg:M1 heir:enumerates
    find:F1_CSTR54 , find:F2_DWB10 , find:F3_UNIX32V ,
    find:F4_V7source , find:F5_PWB , find:F6_USGCanonicalDocs ,
    find:F7_BSTJ1978 , find:F8_Apout , find:F9_PCC , find:F10_EarlyCCompilers ,
    find:F11_EarlyBSD , find:F12_V6Compat , find:F13_KandRDraft77 .

# ---------------------------------------------------------------------
# FINDING 1 — CSTR #54 (Ossanna's troff manual) — literal citation match
# ---------------------------------------------------------------------

find:F1_CSTR54
    a                     heir:Finding , heir:CitationClosure ;
    rdfs:label            "Bell Labs CSTR #54 — Ossanna's NROFF/TROFF User's Manual (1977)" ;
    heir:complementarityScore "83"^^xsd:integer ;
    heir:findingRank      "1"^^xsd:integer ;
    heir:sunsiteResource  pub:CSTR_54 ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Documentation/TechReports/Bell_Labs/CSTRs/54.pdf" ;
    heir:alternateFormat  "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Documentation/TechReports/Bell_Labs/CSTRs/54.ps.gz" ;
    heir:closesCitationIn "/opt/heirloom/src/doctools/BIBLIOGRAPHY.md" ;
    heir:complementary_to heir:Doctools ;
    heir:reasoning
        """Your BIBLIOGRAPHY.md cites this exact CSTR by number: 'Ossanna,
        Joseph F. (1977). "NROFF/TROFF User's Manual." Bell Labs Computing
        Science Technical Report No. 54.' The mirror has both PDF and
        PostScript. This is the strongest citation-closure candidate in
        the corpus — you cite it, we have it. Highest priority.""" ;
    heir:hasDirective     dir:D1_InstallCSTR54 .

dir:D1_InstallCSTR54
    a                     heir:Directive ;
    heir:action           "install locally, update BIBLIOGRAPHY.md to point at the local copy" ;
    heir:suggestedTarget  "/opt/heirloom/share/doc/upstream-citations/CSTR-054-nroff-troff-users-manual.pdf" ;
    heir:priority         "P1-immediate" ;
    heir:respectsProvenance true ;
    rdfs:comment          "Copy, do not move. Preserve the mirror-side original." .

# ---------------------------------------------------------------------
# FINDING 2 — Documenter's Workbench 1.0 — direct code ancestor of doctools
# ---------------------------------------------------------------------

find:F2_DWB10
    a                     heir:Finding , heir:AncestorSource ;
    rdfs:label            "AT&T Documenter's Workbench 1.0 source (dwb_1.0.tar.gz)" ;
    heir:complementarityScore "90"^^xsd:integer ;
    heir:findingRank      "2"^^xsd:integer ;
    heir:sunsiteResource  app:DWB ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Applications/Documenters_Workbench/dwb_1.0.tar.gz" ;
    heir:isAncestorOf     heir:Doctools ;
    heir:enablesComparisonWith heir:Doctools ;
    heir:reasoning
        """DWB 1.0 is the canonical AT&T source that your doctools traces
        to. Ritter's heirloom-doctools descended via OpenSolaris; DWB 1.0
        is the earlier direct ancestor. Enables source-diff study of what
        the port preserves vs modernises. Contains original troff, nroff,
        tbl, eqn, pic, refer, mm/ms macros — a superset of your
        doctools/. This is arguably the most valuable single artefact
        in the corpus for your project.""" ;
    heir:hasDirective     dir:D2_ExtractDWB10 .

dir:D2_ExtractDWB10
    a                     heir:Directive ;
    heir:action           "extract read-only into a reference tree; do not merge with your active source" ;
    heir:suggestedTarget  "/opt/heirloom/src/upstream-ancestors/dwb-1.0/" ;
    heir:priority         "P1-immediate" ;
    heir:respectsProvenance true ;
    heir:downstreamActivity "diff-comparison against src/doctools/, publish findings in a NOTES.md" ;
    rdfs:comment          "Read-only reference. Do NOT overwrite Ritter's heirloom-doctools sources." .

# ---------------------------------------------------------------------
# FINDING 3 — UNIX/32V — the AT&T/BSD divergence point
# ---------------------------------------------------------------------

find:F3_UNIX32V
    a                     heir:Finding , heir:AncestorSource , heir:StructuralExplanation ;
    rdfs:label            "UNIX/32V source (Reiser & London, 1979) — the AT&T/BSD hinge" ;
    heir:complementarityScore "86"^^xsd:integer ;
    heir:findingRank      "3"^^xsd:integer ;
    heir:sunsiteResource  u:v32V ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Distributions/USDL/32V/32v_usr.tar.gz" ;
    heir:relatedPath      "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Distributions/USDL/32V/file2.tar.gz" ;
    heir:relatedPath      "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Documentation/Manuals/UNIX_32V_Version_1.0" ;
    heir:isAncestorOf     heir:Toolchest ;
    heir:isDivergencePointFor heir:Toolchest ;
    heir:complementary_to heir:Toolchest ;
    heir:reasoning
        """32V is THE hinge where AT&T (→ System V → OpenSolaris → your
        bin/) and Berkeley (→ BSDs → your ucb/) diverge. Above 32V there
        is one Unix; below it there are two. Every user of
        /opt/heirloom/ucb/ls versus /opt/heirloom/bin/ls is standing on
        the fault line 32V opened. Studying 32V explains, in source form,
        why your port ships two variants of the same commands.""" ;
    heir:hasDirective     dir:D3_ExtractExplain32V .

dir:D3_ExtractExplain32V
    a                     heir:Directive ;
    heir:action           "extract as read-only reference; author a note explaining bin/ vs ucb/ divergence citing 32V" ;
    heir:suggestedTarget  "/opt/heirloom/src/upstream-ancestors/32v/" ;
    heir:suggestedNote    "/opt/heirloom/src/doctools/../BIN-vs-UCB-DIVERGENCE.md" ;
    heir:priority         "P2-medium" ;
    heir:respectsProvenance true .

# ---------------------------------------------------------------------
# FINDING 4 — V7 source (Spencer + Bostic donor tapes)
# ---------------------------------------------------------------------

find:F4_V7source
    a                     heir:Finding , heir:AncestorSource ;
    rdfs:label            "V7 source — Henry Spencer + Keith Bostic donor tapes (1979)" ;
    heir:complementarityScore "83"^^xsd:integer ;
    heir:findingRank      "4"^^xsd:integer ;
    heir:sunsiteResource  u:v7 ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Distributions/Research/Henry_Spencer_v7/v7.tar.gz" ;
    heir:relatedPath      "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Distributions/Research/Keith_Bostic_v7/" ;
    heir:isAncestorOf     heir:Sh ;
    heir:isAncestorOf     heir:Toolchest ;
    heir:reasoning
        """Henry_Spencer_v7/v7.tar.gz contains the original Stephen Bourne
        shell source — the direct ancestor of your src/sh/. Also contains
        original troff, awk (added later than 1979 but same lineage), and
        the canonical AT&T commands your toolchest bin/ implements.
        Bostic's tape (f0..f5.gz) contains the raw tape records — closer
        to the original distribution format.""" ;
    heir:licensedUnder    c:CalderaLicense2002 ;
    heir:hasDirective     dir:D4_ExtractV7 .

dir:D4_ExtractV7
    a                     heir:Directive ;
    heir:action           "extract Spencer's tape as read-only reference; compare src/sh/ against V7 /bin/sh source" ;
    heir:suggestedTarget  "/opt/heirloom/src/upstream-ancestors/v7/" ;
    heir:priority         "P1-immediate" ;
    heir:respectsProvenance true ;
    heir:cautionsAgainst  "do NOT relicense or redistribute — Caldera 2002 grant covers TUHS Archive distribution, but review the LICENSE terms first" .

# ---------------------------------------------------------------------
# FINDING 5 — PWB/UNIX source — System III/V ancestor
# ---------------------------------------------------------------------

find:F5_PWB
    a                     heir:Finding , heir:AncestorSource ;
    rdfs:label            "PWB/UNIX source (Bostic + Spencer independent donor tapes)" ;
    heir:complementarityScore "80"^^xsd:integer ;
    heir:findingRank      "5"^^xsd:integer ;
    heir:sunsiteResource  u:PWB ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Distributions/USDL/bostic_pwb.tar.gz" ;
    heir:relatedPath      "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Distributions/USDL/spencer_pwb.tar.gz" ;
    heir:isAncestorOf     heir:Toolchest ;
    heir:reasoning
        """PWB is the direct step from V7 towards System III → your
        toolchest's actual upstream. The intermediate stage that
        explains how AT&T commands evolved between Research V7 and
        Solaris. Two independent donor tapes (Bostic + Spencer) for
        cross-verification.""" ;
    heir:licensedUnder    c:CalderaLicense2002 ;
    heir:hasDirective     dir:D5_ExtractPWB .

dir:D5_ExtractPWB
    a                     heir:Directive ;
    heir:action           "extract one tape (Bostic recommended, larger); optionally cross-compare with Spencer" ;
    heir:suggestedTarget  "/opt/heirloom/src/upstream-ancestors/pwb/" ;
    heir:priority         "P2-medium" ;
    heir:respectsProvenance true .

# ---------------------------------------------------------------------
# FINDING 6 — USG Library canonical documentation
# ---------------------------------------------------------------------

find:F6_USGCanonicalDocs
    a                     heir:Finding , heir:CitationClosure , heir:CanonicalDocumentation ;
    rdfs:label            "USG Library canonical documents (#1002, #1004, #1022, #1119)" ;
    heir:complementarityScore "73"^^xsd:integer ;
    heir:findingRank      "6"^^xsd:integer ;
    heir:sunsiteResource  pub:USG_1002 , pub:USG_1004 , pub:USG_1022 , pub:USG_1119 ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Documentation/TechReports/USG_Library/1002_The_C_Programming_Language_Reference_Manual.pdf" ;
    heir:relatedPath      "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Documentation/TechReports/USG_Library/1004_NROFF_Users_Manual.pdf" ;
    heir:relatedPath      "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Documentation/TechReports/USG_Library/1022_NROFF_Macros_for_Producing_Documents.pdf" ;
    heir:relatedPath      "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Documentation/TechReports/USG_Library/1119_NROFF_TROFF_Users_Manual.pdf" ;
    heir:complementary_to heir:Doctools , heir:Devtools ;
    heir:reasoning
        """The USG Library contains 187 canonical AT&T USG (later SVID)
        reference documents including #1002 (the pre-K&R C Reference
        Manual — the language your ccs implements), #1004 (NROFF User's
        Manual — the tool your doctools implements), #1022 (NROFF Macros
        — the mm/ms macros in your doctools), #1119 (NROFF/TROFF Users
        Manual, later revision). These are the exact documentation
        referents for the tools you port.""" ;
    heir:hasDirective     dir:D6_MirrorUSGDocs .

dir:D6_MirrorUSGDocs
    a                     heir:Directive ;
    heir:action           "copy the 4 named PDFs into /opt/heirloom/share/doc/upstream-citations/; consider mirroring the wider 187-doc collection under share/doc/usg-library/ (~200 MB)" ;
    heir:priority         "P2-medium" ;
    heir:respectsProvenance true .

# ---------------------------------------------------------------------
# FINDING 7 — BSTJ 1978 Unix issue (20 iconic Bell Labs papers)
# ---------------------------------------------------------------------

find:F7_BSTJ1978
    a                     heir:Finding , heir:CanonicalDocumentation ;
    rdfs:label            "Bell System Technical Journal 57(6.2), July-August 1978 — 20 canonical Unix papers" ;
    heir:complementarityScore "66"^^xsd:integer ;
    heir:findingRank      "7"^^xsd:integer ;
    heir:sunsiteResource  pub:BSTJ ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Documentation/Papers/BSTJ/" ;
    heir:contains         pub:BSTJ_p1931 , pub:BSTJ_p2115 , pub:BSTJ_p2201 ;
    heir:complementary_to heir:Sh , heir:Doctools ;
    heir:reasoning
        """The iconic BSTJ Unix special issue contains Bourne's shell
        paper (~p.1931 — foundational for your src/sh/), Kernighan+Cherry
        typesetting papers, awk (~p.2201, Aho-Weinberger-Kernighan) —
        the theoretical foundation your BIBLIOGRAPHY implicitly relies
        on. 20 individual PDFs by page number.""" ;
    heir:hasDirective     dir:D7_CopyBSTJ .

dir:D7_CopyBSTJ
    a                     heir:Directive ;
    heir:action           "copy the whole BSTJ directory into share/doc/upstream-citations/BSTJ-1978/; add per-paper annotations if titles are recovered" ;
    heir:priority         "P3-eventual" ;
    heir:respectsProvenance true ;
    heir:downstreamActivity "identify each paper's title from BSTJ index, cross-reference against your BIBLIOGRAPHY" .

# ---------------------------------------------------------------------
# FINDING 8 — Apout emulator — enables live side-by-side testing
# ---------------------------------------------------------------------

find:F8_Apout
    a                     heir:Finding , heir:ComparisonTarget , heir:LiveTestingEnabler ;
    rdfs:label            "Apout — user-mode V7 PDP-11 binary emulator (apout2.3beta1.tar.gz)" ;
    heir:complementarityScore "62"^^xsd:integer ;
    heir:findingRank      "8"^^xsd:integer ;
    heir:sunsiteResource  <https://sunsite.icm.edu.pl/emu#Apout> ;
    heir:hasPath          "/Volumes/mirrors-reduxed/sunsite.icm.edu.pl/packages/UnixArchive/Tools/Emulators/Apout/apout2.3beta1.tar.gz" ;
    heir:enablesComparisonWith heir:Toolchest ;
    heir:reasoning
        """Apout runs original PDP-11 V7 binaries as user-space processes
        on modern Unix. This is the UNIQUE artefact that enables literal
        side-by-side testing: pipe the same input through heirloom-<tool>
        and apout /usr/bin/<tool> (V7 binary), diff the outputs, report
        behavioural drift. Directly complements Heirloom's stated
        preservation mission. Building Apout on Darwin arm64 will require
        porting effort; the source is small.""" ;
    heir:hasDirective     dir:D8_BuildApoutTestHarness .

dir:D8_BuildApoutTestHarness
    a                     heir:Directive ;
    heir:action           "build apout on Darwin arm64; create a test-harness that pipes a corpus through heirloom-<tool> and apout /usr/bin/<tool>, diffs outputs, reports drift" ;
    heir:suggestedTarget  "/opt/heirloom/src/upstream-ancestors/apout/ + /opt/heirloom/tests/live-comparison/" ;
    heir:priority         "P2-medium" ;
    heir:respectsProvenance true ;
    heir:cautionsAgainst  "Apout's licensing terms should be reviewed before including any binaries in installed layout" .

